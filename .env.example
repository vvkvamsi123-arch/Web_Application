# Copy this file to .env.local and fill in all values before running the app.
# .env.local is gitignored and must never be committed.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# PostgreSQL connection string.
# For local development with SQLite, change the provider in prisma/schema.prisma
# to "sqlite" and use: DATABASE_URL="file:./dev.db"
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/harborcart"

# ---------------------------------------------------------------------------
# Auth.js
# ---------------------------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="replace-with-a-random-32-byte-hex-string"
NEXTAUTH_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Google OAuth (Phase 3 — leave blank to skip)
# ---------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ---------------------------------------------------------------------------
# Apple OAuth (Phase 3 — leave blank to skip)
# ---------------------------------------------------------------------------
# APPLE_ID=""
# APPLE_SECRET=""

# ---------------------------------------------------------------------------
# Redis (Phase 4 — optional session store)
# ---------------------------------------------------------------------------
# REDIS_URL="redis://localhost:6379"
